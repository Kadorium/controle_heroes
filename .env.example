# Copie para .env e ajuste conforme o PC servidor da Epic
APP_NAME=Epic Importações
APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-secret-key
HOST=0.0.0.0
PORT=8080

DATABASE_URL=postgresql://postgres@localhost:5433/epic_importacao

ATTACHMENTS_PATH=data/attachments
IMPORTS_PATH=data/imports
BACKUPS_DB_PATH=backups/db
BACKUPS_ATTACHMENTS_PATH=backups/attachments
LOGS_PATH=logs

SESSION_COOKIE_NAME=epic_session
SESSION_MAX_AGE_SECONDS=86400

# Seed admin (primeiro start)
SEED_ADMIN_EMAIL=admin@epic.com.br
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_NAME=Administrador
